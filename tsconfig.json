{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "types": ["vite/client"],
    "paths": {
      "reka-m3": ["./src/index.ts"],
      "reka-m3/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "playground/**/*.ts", "playground/**/*.vue", "vite.config.ts", "env.d.ts"]
}
